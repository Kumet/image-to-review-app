APP_NAME=photo-upload-app
APP_ENV=local
DEBUG=true
HOST=0.0.0.0
PORT=8000
MAX_UPLOAD_FILES=10
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=app/static/uploads
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp
ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
ENABLE_IMAGE_PREVIEW=true
ANALYZER_MODE=ocr
LOG_LEVEL=INFO
ANALYZER_CONFIG_PATH=config/analyzer_settings.json
